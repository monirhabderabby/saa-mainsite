datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

enum AccountStatus {
    PENDING
    ACTIVE
    DEACTIVE
}

enum EmployeeStatus {
    PROBATION
    PARMANENT
}

enum Role {
    SUPER_ADMIN
    ADMIN
    OPERATION_MEMBER
    SALES_MEMBER
}

enum PermissionTool {
    ISSUE_SHEET
    UPDATE_SHEET
}

model User {
    id               String    @id @default(auto()) @map("_id") @db.ObjectId
    fullName         String
    nickName         String    @unique
    email            String    @unique
    image            String?
    employeeId       String    @unique
    dateOfBirth      DateTime?
    parmanentAddress String?
    presentAddress   String?
    phone            String?

    emailVerified DateTime?

    accountStatus  AccountStatus  @default(PENDING)
    employeeStatus EmployeeStatus @default(PROBATION)
    role           Role
    password       String

    designationId String       @db.ObjectId
    designation   Designations @relation(fields: [designationId], references: [id], onDelete: Cascade)

    serviceId String?   @db.ObjectId
    service   Services? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    departmentId String?     @db.ObjectId
    department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    accounts            Account[]
    sessions            Session[]
    permissions         Permissions[]
    userTeams           UserTeam[]
    Authenticator       Authenticator[]
    updateSheetsEntries UpdateSheet[]   @relation("UpdateEntries")
    tlCheckEntries      UpdateSheet[]   @relation("TLChecks")
    doneByEntries       UpdateSheet[]   @relation("DoneByChecks")

    assignments StationAssignment[]

    managedServices Services[] @relation("ServiceManager")

    issueSheets         IssueSheet[]
    statusChangeOnIssue IssueSheet[] @relation("issueShetStatusChange")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tasksId            String?             @db.ObjectId
    projectAssignments ProjectAssignment[]

    projects              Project[]
    salesProjects         Project[]         @relation("SalesPersonProjects")
    projectQnas           ProjectQna[]
    auditLogs             AuditLog[]
    issueActivities       IssueActivity[]   @relation("IssueActivityActor")
    updateSheetActivities UpdateActivity[]  @relation("UpdateActivityActor")
    complaints            Complaint[]
    complaintManager      ComplaintManager?
}

model UserVerification {
    id       String   @id @default(auto()) @map("_id") @db.ObjectId
    userId   String   @db.ObjectId
    expireOn DateTime
    token    String   @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ForgetPasswordLinks {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    userId String @db.ObjectId

    expireOn DateTime
    token    String   @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Services {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String

    teams Team[]
    users User[]

    issues IssueSheet[]

    designations Designations[]

    // 👇 Optional service manager
    serviceManagerId String? @db.ObjectId
    serviceManager   User?   @relation("ServiceManager", fields: [serviceManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    departmentId String?     @db.ObjectId
    department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    updateSheets UpdateSheet[]

    @@unique([name, departmentId])
}

model Designations {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String

    serviceId String   @db.ObjectId
    service   Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    users User[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([serviceId, name])
}

enum DepartmentName {
    Sales
    Operation
    BPU
}

model Department {
    id    String         @id @default(auto()) @map("_id") @db.ObjectId
    name  DepartmentName @unique
    image String?

    // relations
    services Services[]
    teams    Team[]
    users    User[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Profile {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String @unique

    assignments StationAssignmentProfile[]

    updateSheets UpdateSheet[]
    issueSheets  IssueSheet[]

    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    stationAssignments StationAssignment[]
    projects           Project[]
}

model Team {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    name String

    userId    String?      @db.ObjectId
    serviceId String?      @db.ObjectId
    userTeams UserTeam[]
    issues    IssueSheet[]
    service   Services?    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    departmentId String?     @db.ObjectId
    department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    updateSheets UpdateSheet[]
    projects     Project[]
}

model Permissions {
    id   String         @id @default(auto()) @map("_id") @db.ObjectId
    name PermissionTool

    userId String? @db.ObjectId
    user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

    // issue sheet (tool)
    isIssueUpdatAllowed  Boolean @default(true)
    isIssueCreateAllowed Boolean @default(false)

    // update sheet (tool)
    isMessageCreateAllowed  Boolean @default(false)
    isMessageTLCheckAllowed Boolean @default(false)
    isMessageDoneByAllowed  Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(auto()) @map("_id") @db.ObjectId
    userId            String  @db.ObjectId
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    sessionToken String   @unique
    userId       String   @db.ObjectId
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model VerificationToken {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

model Authenticator {
    id                   String  @id @default(auto()) @map("_id") @db.ObjectId
    credentialID         String  @unique
    userId               String  @db.ObjectId
    providerAccountId    String
    credentialPublicKey  String
    counter              Int
    credentialDeviceType String
    credentialBackedUp   Boolean
    transports           String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, credentialID])
}

enum TeamResponsibility {
    Leader
    Coleader
    Member
}

model UserTeam {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    userId String @db.ObjectId
    teamId String @db.ObjectId

    responsibility TeamResponsibility @default(Member)
    user           User               @relation(fields: [userId], references: [id])
    team           Team               @relation(fields: [teamId], references: [id])
}

enum UpdateTo {
    ORDER_PAGE_UPDATE
    INBOX_PAGE_UPDATE
    DELIVERY
    INBOX_AND_ORDER_PAGE_UPDATE
    UPWORK_INBOX
    REVIEW_RESPONSE
    FIVERR_SUPPORT_REPLY
    SPECIAL_ORDER_DELIVERY
}

model UpdateSheet {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    clientName String
    orderId    String

    message String

    attachments          String?
    commentFromOperation String?
    commentFromSales     String?
    updateTo             UpdateTo

    doneById String?   @db.ObjectId
    sendAt   DateTime?
    doneBy   User?     @relation("DoneByChecks", fields: [doneById], references: [id], onDelete: Cascade)

    tlId      String?   @db.ObjectId
    tlCheckAt DateTime?
    tlBy      User?     @relation("TLChecks", fields: [tlId], references: [id], onDelete: Cascade)

    updateById String    @db.ObjectId
    updatedAt  DateTime?
    updateBy   User      @relation("UpdateEntries", fields: [updateById], references: [id], onDelete: Cascade)

    profileId String  @db.ObjectId
    profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    reference String?

    teamId String? @db.ObjectId
    team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

    serviceId String?   @db.ObjectId
    service   Services? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    activities UpdateActivity[]
}

enum IssueStatus {
    open
    wip
    done
    cancelled
    dispute
}

enum RiskLevel {
    low
    medium
    high
    critical
}

model IssueSheet {
    id         String  @id @default(auto()) @map("_id") @db.ObjectId
    clientName String
    orderId    String?

    specialNotes      String?
    orderPageUrl      String?
    inboxPageUrl      String?
    fileOrMeetingLink String?
    noteForSales      String?

    status IssueStatus @default(open)

    statusChangedAt   DateTime?
    statusChangedById String?   @db.ObjectId

    statusChangedBy User? @relation("issueShetStatusChange", fields: [statusChangedById], references: [id], onDelete: Cascade)

    reference String?
    riskLevel RiskLevel @default(low)

    creatorId String @db.ObjectId
    creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

    teamId String? @db.ObjectId
    team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

    serviceId String   @db.ObjectId
    service   Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    profileId String  @db.ObjectId
    profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    activities IssueActivity[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum IssueActivityType {
    COMMENT
    STATUS_CHANGE
    TEAM_ASSIGNED
    ISSUE_UPDATED
    ISSUE_CREATED
}

model IssueActivity {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    type    IssueActivityType
    content String?

    // Optional metadata for system events (e.g., "open → done")
    meta Json?

    issueSheetId String     @db.ObjectId
    issueSheet   IssueSheet @relation(fields: [issueSheetId], references: [id], onDelete: Cascade)

    actorId String @db.ObjectId
    actor   User   @relation("IssueActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@index([issueSheetId])
    @@index([actorId])
}

enum UpdateActivityType {
    COMMENT
    ENTRY_CREATED
    ENTRY_UPDATED
    TL_CHECKED
    TL_UNCHECKED
    MARKED_AS_SENT
    SALES_NOTE_ADDED
    OP_COMMENT_ADDED
}

model UpdateActivity {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    type    UpdateActivityType
    content String?

    // Optional metadata for system events
    meta Json?

    updateSheetId String      @db.ObjectId
    updateSheet   UpdateSheet @relation(fields: [updateSheetId], references: [id], onDelete: Cascade)

    actorId String @db.ObjectId
    actor   User   @relation("UpdateActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@index([updateSheetId])
    @@index([actorId])
}

enum ApplicationStatus {
    live
    maintanance
}

model Settings {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    applicationStatus ApplicationStatus @default(live)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model StationUpdate {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    shift String
    title String

    assignments StationAssignment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model StationAssignment {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    stationId String        @db.ObjectId
    station   StationUpdate @relation(fields: [stationId], references: [id], onDelete: Cascade)

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    profiles StationAssignmentProfile[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    profile   Profile? @relation(fields: [profileId], references: [id])
    profileId String?  @db.ObjectId

    @@unique([stationId, userId])
    @@index([stationId])
    @@index([userId])
}

model StationAssignmentProfile {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    assignmentId String            @db.ObjectId
    assignment   StationAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

    profileId String  @db.ObjectId
    profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    @@unique([assignmentId, profileId])
    @@index([assignmentId])
    @@index([profileId])
}

// project

enum ProjectStatus {
    NRA
    WIP
    Delivered
    Revision
    Cancelled
}

model Project {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    title            String @default("E-Commerce Platform")
    shortDescription String @default("Complete UI/UX redesign with frontend and backend integration")

    clientName String
    orderId    String @unique

    profileId String  @db.ObjectId
    profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    salesPersonId String @db.ObjectId
    salesPerson   User   @relation("SalesPersonProjects", fields: [salesPersonId], references: [id], onDelete: Cascade)

    instructionSheet String
    orderDate        DateTime
    deadline         DateTime
    value            Int
    monetaryValue    Int
    shift            String

    teamId String @db.ObjectId
    team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

    delivered             DateTime?
    probablyWillBeDeliver DateTime?

    supportPeriodStart DateTime?
    supportPeriodEnd   DateTime?

    lastUpdate DateTime?
    nextUpdate DateTime?

    remarkFromOperation String?
    quickNoteFromLeader String?

    review Int?
    status ProjectStatus @default(NRA)

    developmentEnv String?
    productionEnv  String?

    // 👇 Named relations
    projectAssignments ProjectAssignment[]

    progressSheet            String?
    credentialSheet          String?
    websiteIssueTrackerSheet String?

    phase projectPhase[]

    user   User?   @relation(fields: [userId], references: [id])
    userId String? @db.ObjectId

    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    projectQnas ProjectQna[]
}

enum AssignmentRole {
    UIUX
    FRONTEND
    BACKEND
}

model ProjectAssignment {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    projectId String @db.ObjectId

    role AssignmentRole

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    assignedAt DateTime @default(now())
    project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])
}

enum ProjectPhaseStatus {
    Pending
    Completed
    Running
}

model projectPhase {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    title            String
    willBeDeliver    String
    orderId          String?
    value            Int
    monetaryValue    Int
    instructionSheet String?

    status ProjectPhaseStatus

    // ✅ Foreign key to Project
    projectId String  @db.ObjectId
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectQna {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    question String
    answer   String

    projectId String  @db.ObjectId
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    creatorId String @db.ObjectId
    creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum Entity {
    project
    updateSheet
    issueSheet
}

enum AuditAction {
    CREATE
    UPDATE
    DELETE
    STATUS_CHANGE
    DELIVERY_SENT
    UPDATE_SENT
    COMMENT_ADDED
}

model AuditLog {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    entity   Entity
    entityId String @db.ObjectId

    action  AuditAction
    actorId String?     @db.ObjectId
    actor   User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

    changes Json?
    meta    Json?

    createdAt DateTime @default(now())

    @@index([entity, entityId])
    @@index([actorId])
    @@index([action])
    @@index([createdAt])
}

enum ComplaintPriority {
    LOW
    MEDIUM
    HIGH
}

enum ComplaintStatus {
    OPEN
    IN_PROGRESS
    RESOLVED
    REJECTED
}

model Complaint {
    id             String            @id @default(auto()) @map("_id") @db.ObjectId
    uniqueId       String            @unique
    subject        String
    priority       ComplaintPriority
    status         ComplaintStatus   @default(OPEN)
    message        String
    supportingDocs String[]

    creatorId String @db.ObjectId
    creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([creatorId, uniqueId])
}

model ComplaintManager {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    userId String @unique @db.ObjectId
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
}
